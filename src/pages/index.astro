    <!-- ===== Book a call ===== -->
    <section class="schedule" id="schedule">
      <div class="schedule__inner">
        <div>
          <p class="section-kicker" data-reveal>Fifteen minutes, zero pressure</p>
          <h2 class="section-title" data-split>Book a call with Aimee — your way.</h2>
          <div class="schedule__options">
            <a class="schedule__opt" href={site.calendly ? `${site.calendly}/phone-call` : `tel:${site.phoneAimeeHref}`} target={site.calendly ? "_blank" : undefined} rel="noopener" data-reveal>
              <span class="schedule__opt-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M5 4h4l2 5-2.5 1.5a12 12 0 0 0 5 5L15 13l5 2v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z"/></svg>
              </span>
              <span><strong>Phone call</strong><span>Old-fashioned and efficient</span></span>
            </a>
            <a class="schedule__opt" href={site.calendly ? `${site.calendly}/google-meet` : "#contact"} target={site.calendly ? "_blank" : undefined} rel="noopener" data-reveal>
              <span class="schedule__opt-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="2.5" y="6" width="13" height="12" rx="2"/><path d="M15.5 10.5 21 7v10l-5.5-3.5z"/></svg>
              </span>
              <span><strong>Google Meet</strong><span>Video tour of listings together</span></span>
            </a>
            <a class="schedule__opt" href={site.calendly ? `${site.calendly}/microsoft-teams` : "#contact"} target={site.calendly ? "_blank" : undefined} rel="noopener" data-reveal>
              <span class="schedule__opt-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3" y="5" width="12" height="11" rx="2"/><path d="M15 9h5a1 1 0 0 1 1 1v7l-3.5-2H15z"/></svg>
              </span>
              <span><strong>Microsoft Teams</strong><span>Perfect for relocating professionals</span></span>
            </a>
            <a class="schedule__opt" href={site.whatsapp} target="_blank" rel="noopener" data-reveal>
              <span class="schedule__opt-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M12 2.6A9.3 9.3 0 0 0 3.8 16.4L2.6 21l4.7-1.2A9.3 9.3 0 1 0 12 2.6zm0 16.9c-1.5 0-2.9-.4-4.1-1.1l-.3-.2-2.8.7.7-2.7-.2-.3a7.6 7.6 0 1 1 6.7 3.6zm4.2-5.6c-.2-.1-1.4-.7-1.6-.8-.2-.1-.4-.1-.5.1-.2.2-.6.8-.8 1-.1.2-.3.2-.5.1a6.2 6.2 0 0 1-3.1-2.7c-.2-.4 0-.5.2-.7l.5-.6c.1-.2.1-.3 0-.5-.1-.1-.5-1.3-.7-1.8-.2-.5-.4-.4-.5-.4h-.5c-.2 0-.5.1-.7.3-.2.3-.9.9-.9 2.2s.9 2.5 1.1 2.7c.1.2 1.9 2.9 4.6 4 .6.3 1.1.4 1.5.6.6.2 1.2.2 1.6.1.5-.1 1.4-.6 1.6-1.2.2-.6.2-1 .1-1.2 0-.1-.2-.2-.4-.2z"/></svg>
              </span>
              <span><strong>WhatsApp</strong><span>Message Aimee at {site.phoneAimee}</span></span>
            </a>
          </div>
        </div>
        <div class="schedule__embed" data-reveal>
          {site.calendly ? (
            <iframe
              src={`${site.calendly}?hide_gdpr_banner=1&background_color=fffdf9&text_color=14201a&primary_color=b08a4f`}
              width="100%" height="620" frameborder="0" title="Schedule a call with Aimee Greenfield"
            ></iframe>
          ) : (
            <div class="schedule__placeholder">
              <svg viewBox="0 0 64 40" width="64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M2 38 L20 8 L30 24 L38 12 L50 30 L62 38" stroke="#b08a4f" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <h3 style="font-family: var(--font-display); font-weight: 400; font-size: 1.4rem; color: var(--ink);">Online booking is warming up</h3>
              <p>Aimee's live calendar will appear right here. Until then, the fastest routes are a call to <a href={`tel:${site.phoneAimeeHref}`} style="color: var(--brass); font-weight: 600;">{site.phoneAimee}</a> or a <a href={site.whatsapp} style="color: var(--brass); font-weight: 600;">WhatsApp message</a> — she usually answers within minutes.</p>
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- ===== Contact ===== -->
    <section class="contact" id="contact">
      <div class="contact__topo" aria-hidden="true">
        <svg viewBox="0 0 1200 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
          <g fill="none" stroke="currentColor" stroke-width="1">
            <path d="M-50 520 C 200 420, 380 560, 640 480 S 1100 520, 1260 430"/>
            <path d="M-50 470 C 220 370, 400 510, 660 430 S 1080 470, 1260 380"/>
            <path d="M-50 420 C 240 320, 420 460, 680 380 S 1060 420, 1260 330"/>
            <path d="M-50 370 C 260 270, 440 410, 700 330 S 1040 370, 1260 280"/>
            <path d="M-50 320 C 280 220, 460 360, 720 280 S 1020 320, 1260 230"/>
            <path d="M-50 270 C 300 170, 480 310, 740 230 S 1000 270, 1260 180"/>
          </g>
        </svg>
      </div>

      <div class="contact__inner">
        <div class="contact__info">
          <p class="section-kicker section-kicker--light" data-reveal>Visit, call, or write</p>
          <h2 class="section-title section-title--light" data-split>The kettle’s on at the Sparta office.</h2>
          <ul class="contact__list">
            <li data-reveal>
              <span>Office</span>
              <p>{site.address.street}<br/>{site.address.city}, {site.address.state} {site.address.zip}</p>
            </li>
            <li data-reveal>
              <span>Hours</span>
              <p>Mon – Sat · 9:00 am – 5:30 pm<br/>Sunday by appointment</p>
            </li>
            <li data-reveal>
              <span>Phone</span>
              <p><a href={`tel:${site.phoneOfficeHref}`}>{site.phoneOffice}</a> office<br/><a href={`tel:${site.phoneAimeeHref}`}>{site.phoneAimee}</a> Aimee direct · <a href={site.whatsapp} target="_blank" rel="noopener">WhatsApp</a></p>
            </li>
            <li data-reveal>
              <span>Email</span>
              <p><a href={`mailto:${site.email}`}>{site.email}</a></p>
            </li>
          </ul>
          <figure class="contact__office" data-reveal>
            <img src="/assets/office.jpg" alt="The Greenfield Acres Realty log-cabin office on US-21 in Sparta" loading="lazy" />
            <figcaption>Our cabin on US-21 — come on up, the porch light’s on.</figcaption>
          </figure>
        </div>

        <form class="contact__form" data-reveal name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/thanks">
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden-field" aria-hidden="true"><label>Don’t fill this out: <input name="bot-field" /></label></p>
          <h3>Tell us what you’re dreaming of</h3>
          <div class="field">
            <label for="f-name">Name</label>
            <input id="f-name" name="name" type="text" placeholder="Your name" required />
          </div>
          <div class="field">
            <label for="f-email">Email</label>
            <input id="f-email" name="email" type="email" placeholder="you@example.com" required />
          </div>
          <div class="field">
            <label for="f-phone">Phone (optional)</label>
            <input id="f-phone" name="phone" type="tel" placeholder="Best number to reach you" />
          </div>
          <div class="field">
            <label for="f-msg">Message</label>
            <textarea id="f-msg" name="message" rows="4" placeholder="Buying, selling, land, cabins — tell us everything."></textarea>
          </div>
          <button class="btn btn--brass" type="submit"><span>Send Message</span></button>
          <p class="contact__form-note">Prefer to talk? Aimee usually answers within minutes.</p>
        </form>
      </div>
    </section>

    <!-- Netlify Forms registration for the Home-Finder wizard (submitted via JS) -->
    <form name="home-finder" data-netlify="true" netlify-honeypot="bot-field" hidden aria-hidden="true">
      <input type="text" name="name" />
      <input type="text" name="contact" />
      <input type="text" name="intent" />
      <input type="text" name="budget" />
      <input type="text" name="timeline" />
      <input type="text" name="towns" />
      <input type="text" name="style" />
      <input type="text" name="musthaves" />
      <textarea name="notes"></textarea>
      <input name="bot-field" />
    </form>

  </main>

</Base>

<script is:inline src="/finder.js" defer></script>
