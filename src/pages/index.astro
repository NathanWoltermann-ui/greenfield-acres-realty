        <article class="member" data-reveal>
          <div class="member__monogram">AA</div>
          <h3>Andrew Aaron</h3>
          <p class="member__role">Premier Lender</p>
          <p class="member__bio">Trusted financing partner for buyers across the High Country.</p>
          <div class="member__contact">
            <a href="tel:+18284463971">828-446-3971</a>
          </div>
        </article>
