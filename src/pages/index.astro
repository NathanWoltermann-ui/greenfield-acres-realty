---
import Base from "../layouts/Base.astro";
import site from "../data/site.json";
import SearchPanel from "../components/SearchPanel.astro";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "RealEstateAgent",
  name: "Greenfield Acres Realty",
  slogan: "Where the grass is always green",
  url: "https://www.greenfieldacresrealty.com",
  logo: "https://www.greenfieldacresrealty.com/assets/logo.jpg",
  telephone: "+1-336-223-3771",
  email: site.email,
  address: {
    "@type": "PostalAddress",
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    addressRegion: site.address.state,
    postalCode: site.address.zip,
    addressCountry: "US",
  },
  areaServed: ["Sparta NC", "Blowing Rock NC", "Boone NC", "Banner Elk NC", "West Jefferson NC", "Alleghany County NC", "Ashe County NC", "Watauga County NC"],
  openingHours: "Mo-Sa 09:00-17:30",
  sameAs: [site.social.facebook, site.social.instagram, site.social.linkedin, site.social.yelp],
  founder: { "@type": "Person", name: "Aimee Greenfield", jobTitle: "Owner & Broker-in-Charge" },
};
---
<Base preloader={true} bodyClass="page-home">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <main id="top">

    <!-- ===== Hero ===== -->
    <section class="hero" id="hero">
      <div class="hero__media" data-hero-media>
        <img
          src="/assets/heroes/ridge-mist.jpg"
          alt="Layered blue ridges of the North Carolina High Country at misty sunrise"
          fetchpriority="high" />
        <div class="hero__veil"></div>
        <div class="hero__mist"></div>
      </div>

      <div class="hero__content">
        <p class="hero__eyebrow" data-hero-fade>
          <span class="hero__eyebrow-line"></span>
          Sparta · Blowing Rock · Boone — North Carolina
        </p>
        <h1 class="hero__title" data-hero-title>
          <span class="line"><span>Find your place</span></span>
          <span class="line"><span>in the <em>High&nbsp;Country.</em></span></span>
        </h1>
        <p class="hero__lede" data-hero-fade>
          Luxury home specialists of the Blue Ridge Mountains. Let us sell — or
          help you find — your dream home in the High Country.
        </p>
        <div class="hero__actions" data-hero-fade>
          <a class="btn btn--solid" href="#listings"><span>View Featured Homes</span></a>
          <a class="btn btn--ghost" href="#finder"><span>Find My Mountain Home</span></a>
        </div>
      </div>

      <div class="hero__foot" data-hero-fade>
        <div class="hero__stat">
          <strong>5.0</strong>
          <span>★★★★★ client rating</span>
        </div>
        <div class="hero__stat">
          <strong>NC&nbsp;+&nbsp;VA</strong>
          <span>Licensed broker, two states</span>
        </div>
        <div class="hero__stat">
          <strong>CLHMS</strong>
          <span>Certified Luxury Home Specialist</span>
        </div>
        <a class="hero__scroll" href="#marquee" aria-label="Scroll down">
          <span class="hero__scroll-track"><span class="hero__scroll-dot"></span></span>
        </a>
      </div>
    </section>

    <!-- ===== Marquee ===== -->
    <section class="marquee" id="marquee" aria-hidden="true">
      <div class="marquee__track">
        <span>Sparta</span><i>✦</i><span>Blowing Rock</span><i>✦</i><span>Boone</span><i>✦</i><span>West Jefferson</span><i>✦</i><span>Banner Elk</span><i>✦</i><span>Glade Valley</span><i>✦</i><span>Laurel Springs</span><i>✦</i><span>Roaring Gap</span><i>✦</i>
        <span>Sparta</span><i>✦</i><span>Blowing Rock</span><i>✦</i><span>Boone</span><i>✦</i><span>West Jefferson</span><i>✦</i><span>Banner Elk</span><i>✦</i><span>Glade Valley</span><i>✦</i><span>Laurel Springs</span><i>✦</i><span>Roaring Gap</span><i>✦</i>
      </div>
    </section>

    <!-- ===== Intro / Manifesto ===== -->
    <section class="intro">
      <div class="intro__inner">
        <p class="intro__kicker" data-reveal>The Greenfield standard</p>
        <h2 class="intro__statement" data-split>
          Every client is our number one priority — with the marketing reach of a
          luxury brokerage and the heart of a small mountain town.
        </h2>
        <div class="intro__meta">
          <div class="intro__stat" data-reveal>
            <strong><span data-count="45">0</span>+</strong>
            <span>Five-star client reviews</span>
          </div>
          <div class="intro__stat" data-reveal>
            <strong><span data-count="2">0</span></strong>
            <span>States licensed — NC &amp; VA</span>
          </div>
          <div class="intro__stat" data-reveal>
            <strong><span data-count="13">0</span></strong>
            <span>High Country communities served</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== Featured Listings (horizontal scroll) ===== -->
    <section class="listings" id="listings">
      <div class="listings__head">
        <p class="section-kicker" data-reveal>Featured properties</p>
        <h2 class="section-title" data-split>Homes worth the drive up the mountain.</h2>
        <p class="listings__hint" data-reveal>Scroll&nbsp;→&nbsp;&nbsp;Live MLS featured listings — call <a href={`tel:${site.phoneOfficeHref}`}>{site.phoneOffice}</a> for showings.</p>
      </div>

      <div class="listings__pin" data-listings-pin>
        <div class="listings__track" data-listings-track data-featured-track>

          <article class="card">
            <div class="card__media">
              <img loading="lazy" src="/assets/listings/eagle-cliff-trail.jpg" alt="Timber mountain home with red metal roof at 745 Eagle Cliff Trail" />
              <span class="card__tag">Mountain Lodge</span>
            </div>
            <div class="card__body">
              <div class="card__top">
                <h3>745 Eagle Cliff Trail</h3>
              </div>
              <p class="card__loc">Banner Elk, NC</p>
              <p class="card__inquire"><a href={`tel:${site.phoneOfficeHref}`}>Call for details →</a></p>
            </div>
          </article>

          <article class="card">
            <div class="card__media">
              <img loading="lazy" src="/assets/listings/beacon-hill.jpg" alt="Shingle and stone estate at 260 Beacon Hill" />
              <span class="card__tag">Estate</span>
            </div>
            <div class="card__body">
              <div class="card__top">
                <h3>260 Beacon Hill</h3>
              </div>
              <p class="card__loc">Blowing Rock, NC</p>
              <p class="card__inquire"><a href={`tel:${site.phoneOfficeHref}`}>Call for details →</a></p>
            </div>
          </article>

          <article class="card">
            <div class="card__media">
              <img loading="lazy" src="/assets/listings/stonecrop-lane.jpg" alt="Timber-frame home with long-range mountain views at 153 Stonecrop Lane" />
              <span class="card__tag">Timber Frame</span>
            </div>
            <div class="card__body">
              <div class="card__top">
                <h3>153 Stonecrop Lane</h3>
              </div>
              <p class="card__loc">Boone, NC</p>
              <p class="card__inquire"><a href={`tel:${site.phoneOfficeHref}`}>Call for details →</a></p>
            </div>
          </article>

          <article class="card">
            <div class="card__media">
              <img loading="lazy" src="/assets/listings/bryan-hollow-road.jpg" alt="Large log home at 904 Bryan Hollow Road" />
              <span class="card__tag">Log Home</span>
            </div>
            <div class="card__body">
              <div class="card__top">
                <h3>904 Bryan Hollow Road</h3>
              </div>
              <p class="card__loc">Boone, NC</p>
              <p class="card__inquire"><a href={`tel:${site.phoneOfficeHref}`}>Call for details →</a></p>
            </div>
          </article>

          <article class="card">
            <div class="card__media">
              <img loading="lazy" src="/assets/listings/howards-knob-road.jpg" alt="Stone manor home with mountain view at 530 Howards Knob Road" />
              <span class="card__tag">Stone Manor</span>
            </div>
            <div class="card__body">
              <div class="card__top">
                <h3>530 Howards Knob Rd.</h3>
              </div>
              <p class="card__loc">Boone, NC</p>
              <p class="card__inquire"><a href={`tel:${site.phoneOfficeHref}`}>Call for details →</a></p>
            </div>
          </article>

          <article class="card">
            <div class="card__media">
              <img loading="lazy" src="/assets/listings/joriann-drive.jpg" alt="Stone farmhouse with fenced pasture at 199 Joriann Drive" />
              <span class="card__tag">Farm &amp; Acreage</span>
            </div>
            <div class="card__body">
              <div class="card__top">
                <h3>199 Joriann Drive</h3>
              </div>
              <p class="card__loc">Crumpler, NC</p>
              <p class="card__inquire"><a href={`tel:${site.phoneOfficeHref}`}>Call for details →</a></p>
            </div>
          </article>

          <article class="card">
            <div class="card__media">
              <img loading="lazy" src="/assets/listings/blackberry-lane.jpg" alt="Craftsman home with stone landscaping at 119 Blackberry Lane" />
              <span class="card__tag">Craftsman</span>
            </div>
            <div class="card__body">
              <div class="card__top">
                <h3>119 Blackberry Lane</h3>
              </div>
              <p class="card__loc">Boone, NC</p>
              <p class="card__inquire"><a href={`tel:${site.phoneOfficeHref}`}>Call for details →</a></p>
            </div>
          </article>

          <article class="card">
            <div class="card__media">
              <img loading="lazy" src="/assets/listings/glade-valley-road.jpg" alt="Ranch home with Blue Ridge backdrop at 438 Glade Valley Road" />
              <span class="card__tag">Ranch &amp; Views</span>
            </div>
            <div class="card__body">
              <div class="card__top">
                <h3>438 Glade Valley Road</h3>
              </div>
              <p class="card__loc">Glade Valley, NC</p>
              <p class="card__inquire"><a href={`tel:${site.phoneOfficeHref}`}>Call for details →</a></p>
            </div>
          </article>

          <article class="card card--cta">
            <div class="card--cta__inner">
              <h3>Looking for land, a farm, or something off-market?</h3>
              <p>Aimee’s network across Alleghany, Ashe &amp; Watauga counties surfaces properties before they hit the MLS.</p>
              <a class="btn btn--solid" href="/land"><span>Explore Land &amp; Acreage</span></a>
            </div>
          </article>

        </div>
      </div>
    </section>

    <!-- ===== Property Search ===== -->
    <section class="search-strip" id="search">
      <div class="search-strip__head">
        <p class="section-kicker section-kicker--light" data-reveal>Search the MLS</p>
        <h2 class="section-title section-title--light" data-split>Every listing on the mountain, one search away.</h2>
      </div>
      <div class="search-strip__inner">
        <SearchPanel />
      </div>
    </section>

    <!-- ===== Communities ===== -->
    <section class="communities" id="communities">
      <div class="communities__head">
        <p class="section-kicker" data-reveal>Where we work</p>
        <h2 class="section-title" data-split>Thirteen towns. One backyard: the Blue&nbsp;Ridge.</h2>
      </div>
      <div class="communities__grid">
        <a class="place" href="/communities/sparta" data-reveal-img>
          <div class="place__media">
            <img loading="lazy" src="/assets/heroes/pasture-road.jpg" alt="Golden pasture and country road near Sparta" />
          </div>
          <div class="place__body">
            <span class="place__num">01</span>
            <h3>Sparta</h3>
            <p>The quiet heart of Alleghany County — Christmas-tree farms, the New River, and our home office on US-21.</p>
            <span class="place__link">Explore Sparta →</span>
          </div>
        </a>
        <a class="place" href="/communities/blowing-rock" data-reveal-img>
          <div class="place__media">
            <img loading="lazy" src="/assets/heroes/sunbeam-valley.jpg" alt="Sunbeams over green Blue Ridge valley at Blowing Rock" />
          </div>
          <div class="place__body">
            <span class="place__num">02</span>
            <h3>Blowing Rock</h3>
            <p>The crown of the Blue Ridge Parkway — storybook village charm with the High Country’s finest estates.</p>
            <span class="place__link">Explore Blowing Rock →</span>
          </div>
        </a>
        <a class="place" href="/communities/boone" data-reveal-img>
          <div class="place__media">
            <img loading="lazy" src="/assets/heroes/forest-light.jpg" alt="Sunlight through tall forest near Boone" />
          </div>
          <div class="place__body">
            <span class="place__num">03</span>
            <h3>Boone</h3>
            <p>The hub of the High Country — college-town energy, four-season trails, and strong investment demand.</p>
            <span class="place__link">Explore Boone →</span>
          </div>
        </a>
      </div>
      <div class="communities__more" data-reveal>
        <a class="btn btn--ghost" href="/communities"><span>See All 13 Communities</span></a>
      </div>
    </section>

    <!-- ===== Home-Finder wizard ===== -->
    <section class="finder" id="finder">
      <div class="finder__inner">
        <div class="finder__head">
          <p class="section-kicker section-kicker--light" data-reveal>Find your High Country home</p>
          <h2 class="section-title section-title--light" data-split>Answer six questions. We'll chart your trail.</h2>
        </div>

        <div class="finder__progress"><div class="finder__progress-bar" data-finder-progress></div></div>

        <div class="finder__stage" data-finder>

          <div class="finder__step is-active" data-step="intent">
            <h3 class="finder__q">What brings you up the mountain?</h3>
            <p class="finder__hint">Pick the one that fits best.</p>
            <div class="finder__options">
              <button class="finder__opt" data-value="primary"><strong>A primary home</strong><small>We're moving to the mountains</small></button>
              <button class="finder__opt" data-value="second-home"><strong>A second home</strong><small>Weekends, summers & holidays</small></button>
              <button class="finder__opt" data-value="retirement"><strong>Retirement</strong><small>The view we've earned</small></button>
              <button class="finder__opt" data-value="investment"><strong>An investment</strong><small>Rental or long-term hold</small></button>
              <button class="finder__opt" data-value="selling"><strong>I'm selling</strong><small>List my High Country property</small></button>
            </div>
          </div>

          <div class="finder__step" data-step="budget">
            <h3 class="finder__q">What budget are we working with?</h3>
            <p class="finder__hint">A range is plenty — this just points the search.</p>
            <div class="finder__options">
              <button class="finder__opt" data-value="under-400"><strong>Under $400k</strong><small>Cabins, cottages & land</small></button>
              <button class="finder__opt" data-value="400-800"><strong>$400k – $800k</strong><small>The heart of the market</small></button>
              <button class="finder__opt" data-value="800-1500"><strong>$800k – $1.5M</strong><small>Luxury homes & estates</small></button>
              <button class="finder__opt" data-value="over-1500"><strong>$1.5M+</strong><small>Signature properties</small></button>
              <button class="finder__opt" data-value="land"><strong>Land budget</strong><small>Buying acreage to build</small></button>
            </div>
          </div>

          <div class="finder__step" data-step="timeline">
            <h3 class="finder__q">When would you like keys in hand?</h3>
            <p class="finder__hint">No wrong answers — dreamers welcome.</p>
            <div class="finder__options">
              <button class="finder__opt" data-value="asap"><strong>As soon as possible</strong><small>Ready to move now</small></button>
              <button class="finder__opt" data-value="3-6-months"><strong>3 – 6 months</strong><small>Actively planning</small></button>
              <button class="finder__opt" data-value="6-12-months"><strong>6 – 12 months</strong><small>Getting serious</small></button>
              <button class="finder__opt" data-value="dreaming"><strong>Just dreaming</strong><small>Researching the mountains</small></button>
            </div>
          </div>

          <div class="finder__step" data-step="towns">
            <h3 class="finder__q">Any towns calling your name?</h3>
            <p class="finder__hint">Choose as many as you like, then continue.</p>
            <div class="finder__options finder__options--multi" data-multi>
              <button class="finder__opt" data-value="Sparta"><strong>Sparta</strong><small>Farm valleys & the New River</small></button>
              <button class="finder__opt" data-value="Blowing Rock"><strong>Blowing Rock</strong><small>Storybook village, top estates</small></button>
              <button class="finder__opt" data-value="Boone"><strong>Boone</strong><small>The High Country hub</small></button>
              <button class="finder__opt" data-value="Banner Elk"><strong>Banner Elk</strong><small>Ski country & gated communities</small></button>
              <button class="finder__opt" data-value="West Jefferson"><strong>West Jefferson</strong><small>The arts town</small></button>
              <button class="finder__opt" data-value="not-sure"><strong>Not sure yet</strong><small>Let Aimee advise us</small></button>
            </div>
            <div class="finder__nav">
              <button class="finder__back" data-finder-back>← Back</button>
              <button class="btn btn--brass" data-finder-next><span>Continue</span></button>
            </div>
          </div>

          <div class="finder__step" data-step="style">
            <h3 class="finder__q">What does "home" look like up here?</h3>
            <p class="finder__hint">Pick your favorite.</p>
            <div class="finder__options">
              <button class="finder__opt" data-value="log-cabin"><strong>Log cabin / lodge</strong><small>Timber, stone & firewood</small></button>
              <button class="finder__opt" data-value="farm"><strong>Farm & acreage</strong><small>Pasture, barns, elbow room</small></button>
              <button class="finder__opt" data-value="estate"><strong>Luxury estate</strong><small>Views, gates & guest wings</small></button>
              <button class="finder__opt" data-value="village"><strong>Village home</strong><small>Walk to Main Street</small></button>
              <button class="finder__opt" data-value="build"><strong>Land to build on</strong><small>The perfect parcel first</small></button>
            </div>
          </div>

          <div class="finder__step" data-step="musthaves">
            <h3 class="finder__q">Any non-negotiables?</h3>
            <p class="finder__hint">Choose all that apply, then continue.</p>
            <div class="finder__options finder__options--multi" data-multi>
              <button class="finder__opt" data-value="Long-range mountain view">Long-range mountain view</button>
              <button class="finder__opt" data-value="River or creek frontage">River / creek frontage</button>
              <button class="finder__opt" data-value="5+ acres">5+ acres</button>
              <button class="finder__opt" data-value="Gated community">Gated community</button>
              <button class="finder__opt" data-value="Ski access">Ski access</button>
              <button class="finder__opt" data-value="Rental potential">Rental potential</button>
            </div>
            <div class="finder__nav">
              <button class="finder__back" data-finder-back>← Back</button>
              <button class="btn btn--brass" data-finder-next><span>Continue</span></button>
            </div>
          </div>

          <div class="finder__step" data-step="contact">
            <h3 class="finder__q">Where should Aimee send your matches?</h3>
            <p class="finder__hint">She reads every one of these herself — no drip campaigns, promise.</p>
            <div class="field">
              <label for="fin-name">Name</label>
              <input id="fin-name" type="text" placeholder="Your name" data-fin-name />
            </div>
            <div class="field">
              <label for="fin-contact">Email or phone</label>
              <input id="fin-contact" type="text" placeholder="How should she reach you?" data-fin-contact />
            </div>
            <div class="field">
              <label for="fin-notes">Anything else? (optional)</label>
              <textarea id="fin-notes" rows="2" placeholder="The porch faces west, the dog needs a creek…" data-fin-notes></textarea>
            </div>
            <div class="finder__nav">
              <button class="finder__back" data-finder-back>← Back</button>
              <button class="btn btn--brass" data-finder-submit><span>Get My Matches</span></button>
            </div>
          </div>

          <div class="finder__step" data-step="result">
            <div class="finder__result-summary" data-finder-summary></div>
            <div class="finder__result-links" data-finder-links></div>
          </div>

        </div>
      </div>
    </section>

    <!-- ===== About Aimee ===== -->
    <section class="about" id="about">
      <div class="about__media" data-reveal-img data-parallax>
        <img loading="lazy" src="/assets/heroes/ridgelines.jpg" alt="Layered misty Blue Ridge mountain ridgelines" />
        <figcaption class="about__caption">The Blue Ridge Mountains — home since day one of Greenfield Acres.</figcaption>
        <figure class="about__portrait" data-reveal>
          <img src="/assets/aimee.jpg" alt="Aimee Greenfield, Owner and Broker-in-Charge" />
          <figcaption>Aimee Greenfield</figcaption>
        </figure>
      </div>
      <div class="about__body">
        <p class="section-kicker" data-reveal>Owner &amp; Broker-in-Charge</p>
        <h2 class="section-title" data-split>Aimee Greenfield sees homes the way she once drew them.</h2>
        <p class="about__text" data-reveal>
          Before real estate, Aimee’s world was <em>interior design and architecture</em> —
          a trained eye she now puts to work pricing, staging, and marketing every
          property she represents. After living in Ohio, California, and Montana,
          she settled in the Blue Ridge Mountains of North Carolina and built
          Greenfield Acres Realty around one idea: with this much time dedicated
          to each client, <em>you always feel like the number one priority.</em>
        </p>
        <ul class="about__creds">
          <li data-reveal><strong>CLHMS</strong><span>Certified Luxury Home Marketing Specialist</span></li>
          <li data-reveal><strong>BIC — NC &amp; VA</strong><span>Broker-in-Charge, licensed in two states</span></li>
          <li data-reveal><strong>Millionaires Club</strong><span>Top-producing sales recognition</span></li>
          <li data-reveal><strong>Chambers of Commerce</strong><span>Alleghany &amp; Blowing Rock member</span></li>
        </ul>
        <div class="about__seals" data-reveal>
          <img src="/assets/seal-member.jpg" alt="Institute for Luxury Home Marketing — Member" loading="lazy" />
          <img src="/assets/seal-clhms.jpg" alt="Certified Luxury Home Marketing Specialist seal" loading="lazy" />
          <img src="/assets/seal-guild.jpg" alt="CLHMS Guild seal" loading="lazy" />
        </div>
        <div class="about__actions" data-reveal>
          <a class="btn btn--solid" href={`tel:${site.phoneAimeeHref}`}><span>Call Aimee — {site.phoneAimee}</span></a>
          <a class="btn btn--ghost" href={site.whatsapp} target="_blank" rel="noopener"><span>WhatsApp Aimee</span></a>
        </div>
      </div>
    </section>

    <!-- ===== Affiliations ===== -->
    <section class="affiliations" aria-label="Memberships and recognition">
      <p class="section-kicker" data-reveal>Memberships &amp; recognition</p>
      <div class="affiliations__row" data-reveal>
        <img src="/assets/badge-realtor-mls.jpg" alt="REALTOR® — Multiple Listing Service member" loading="lazy" title="REALTOR® · High Country Association of REALTORS® MLS" />
        <img src="/assets/badge-zillow.jpg" alt="Zillow Premier Agent" loading="lazy" title="Zillow Premier Agent" />
        <img src="/assets/badge-homelight.jpg" alt="HomeLight Sells For More 2018 award" loading="lazy" title="HomeLight — Sells For More award" />
        <img src="/assets/badge-chamber-alleghany.jpg" alt="Member, Alleghany County Chamber of Commerce" loading="lazy" title="Alleghany County Chamber of Commerce" />
        <img src="/assets/badge-chamber-blowingrock.jpg" alt="Member, Blowing Rock Chamber of Commerce" loading="lazy" title="Blowing Rock Chamber of Commerce" />
        <img src="/assets/badge-equal-housing.jpg" alt="Equal Housing Opportunity" loading="lazy" title="Equal Housing Opportunity" />
      </div>
    </section>

    <!-- ===== Reviews ===== -->
    <section class="reviews" id="reviews">
      <div class="reviews__head">
